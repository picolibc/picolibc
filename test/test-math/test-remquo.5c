load "test-float.5c"

typedef struct {
	real x, y;
} pair_t;

const int quo_mask = 0x7;

pair_t[] test_values = {
	{ .x = 0x1.fffffep127, .y = 0x1.fffffep-126 },
	{ .x = 0x1.fffffffffffffp1023, .y = 0x1.fffffffffffffp-1022 },
	{ .x = 0x1.fffffffffffffffep16383, .y = 0x1.fffffffffffffffep-16381 },
	{ .x = 0x1.ffffffffffffffffffffffffffffp16383, .y = 0x1.ffffffffffffffffffffffffffffp-16382 },
};

real
quo(real x, real y)
{
	real n = 0;
	if (is_inf(x) || y == 0)
		return quo_mask+1;
	try {
		real quo = floor(x / y + 0.5);
		if (quo < 0) {
			n = -((-quo) & quo_mask);
		} else {
			n = quo & quo_mask;
		}
	} catch invalid_binop_values(string message, poly x, poly y) {
		return 0;
	} catch invalid_unop_value(string message, poly x) {
		return 0;
	}
	return n;
}

void
compute_signs(real xi, real yi)
{
	compute_real_real( xi,  yi, quo);
	compute_real_real(-xi,  yi, quo);
	compute_real_real( xi, -yi, quo);
	compute_real_real(-xi, -yi, quo);
}

void
main()
{
	for (int i = 0; i < dim(test_values); i++) {
		real xi = imprecise(test_values[i].x, prec);
		real yi = imprecise(test_values[i].y, prec);
		compute_signs(xi, xi);
		compute_signs(xi, yi);
		compute_signs(yi, xi);
		compute_signs(yi, yi);
	}
	for (real x = 1e-38; x <= 1e38; x *= 1111) {
		for (real y = 1e-38; y <= 1e38; y *= 1111) {
			real xi = imprecise(x, prec);
			real yi = imprecise(y, prec);
			compute_signs(xi, yi);
		}
	}
}

main();
